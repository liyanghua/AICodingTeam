# Mobile Asset Center on cloud server
ASSET_CENTER_PROFILE=cloud
ASSET_CENTER_STORAGE_PROVIDER=aliyun_oss
ASSET_CENTER_SYNC_TOKEN=replace-with-shared-sync-token

ASSET_CENTER_DB_DSN=postgresql://user:password@pg.example.com:5432/asset_center

ALIYUN_OSS_BUCKET=your-bucket
ALIYUN_OSS_ENDPOINT=oss-cn-hangzhou.aliyuncs.com
ALIYUN_OSS_ACCESS_KEY_ID=your-access-key-id
ALIYUN_OSS_ACCESS_KEY_SECRET=your-access-key-secret

ASSET_CENTER_URL_EXPIRES_SECONDS=3600
