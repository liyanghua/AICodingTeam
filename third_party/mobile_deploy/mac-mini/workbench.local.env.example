# Local validation profile for Mobile Image Workbench
MWB_ADMIN_TOKEN=replace-with-local-admin-token
MWB_CLOUD_SERVER_URL=http://127.0.0.1:8876
MWB_CLOUD_SYNC_TOKEN=replace-with-local-or-cloud-sync-token
MWB_COLLECTOR_ID=local-validation

# Qwen-VL / DashScope scene tagging for local validation
DASHSCOPE_API_KEY=replace-with-dashscope-key
DASHSCOPE_VLM_MODEL=qwen-vl-max
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional local tuning
MWB_SCENE_TAG_PROVIDER=openai_compatible
MWB_SCENE_TAG_LIMIT=50
MWB_SYNC_BATCH_SIZE=50
