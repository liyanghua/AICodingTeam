# Remote deployment target for Mac mini collection workbench
#
# Copy this file to:
#   third_party/mobile_deploy/mac-mini/.env.remote
#
# This file is read only by the workbench admin remote deploy action.
# Do not put these values in third_party/mobile_asset_center/.env.asset.cloud.

# Preferred format: user@host-or-ip
MWB_MAC_MINI_SSH_TARGET=deploy@192.168.77.35

# Existing repository root on the Mac mini, or the directory where rsync should create it.
MWB_MAC_MINI_REMOTE_ROOT=/Users/deploy/mobile-runtime

# Workbench env file that already exists on the remote Mac mini.
# It is not rsynced from the local machine, so Mac mini secrets stay remote.
MWB_MAC_MINI_WORKBENCH_ENV_FILE=/Users/deploy/mobile-runtime/third_party/mobile_image_workbench/.env.mac-mini

# Prefer SSH key auth when possible.
MWB_MAC_MINI_SSH_KEY_PATH=/Users/you/.ssh/mac-mini-deploy
MWB_MAC_MINI_SSH_PORT=22

# Password auth fallback. Requires sshpass on the machine that starts deployment.
# MWB_MAC_MINI_SSH_PASS=replace-with-password
