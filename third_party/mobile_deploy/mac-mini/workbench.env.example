# Mobile Image Workbench on Mac mini
MWB_ADMIN_TOKEN=replace-with-local-admin-token
MWB_CLOUD_SERVER_URL=http://asset-center.internal
MWB_CLOUD_SYNC_TOKEN=replace-with-shared-sync-token
MWB_COLLECTOR_ID=mac-mini-01

# Qwen-VL / DashScope scene tagging
DASHSCOPE_API_KEY=replace-with-dashscope-key
DASHSCOPE_VLM_MODEL=qwen-vl-max
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional tuning
MWB_SCENE_TAG_PROVIDER=openai_compatible
MWB_SCENE_TAG_LIMIT=200
MWB_SYNC_BATCH_SIZE=100

# Optional one-click cloud asset center deployment from the workbench admin page
MWB_DEPLOY_SSH_HOST=asset-center.internal
MWB_DEPLOY_SSH_USER=deploy
MWB_DEPLOY_SSH_KEY_PATH=/Users/you/.ssh/mobile_asset_center
MWB_DEPLOY_SSH_PORT=22
MWB_DEPLOY_REMOTE_ROOT=/tmp/mobile-deploy-workspace
MWB_DEPLOY_REMOTE_INSTALL_DIR=/opt/mobile_asset_center
MWB_DEPLOY_HOST_NAME=_
