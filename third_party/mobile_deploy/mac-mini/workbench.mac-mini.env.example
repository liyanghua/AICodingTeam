# Remote Mac mini production workbench profile
MWB_ADMIN_TOKEN=replace-with-mac-mini-admin-token
MWB_CLOUD_SERVER_URL=http://asset-center.internal
MWB_CLOUD_SYNC_TOKEN=replace-with-shared-sync-token
MWB_COLLECTOR_ID=mac-mini-01

# Mac mini Python and Android paths
MWB_PYTHON_BIN=/opt/homebrew/bin/python3.12
ANDROID_HOME=/Users/deploy/Library/Android/sdk

# Qwen-VL / DashScope scene tagging
DASHSCOPE_API_KEY=replace-with-dashscope-key
DASHSCOPE_VLM_MODEL=qwen-vl-max
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional tuning
MWB_SCENE_TAG_PROVIDER=openai_compatible
MWB_SCENE_TAG_LIMIT=200
MWB_SYNC_BATCH_SIZE=100

# Optional pip mirror for the Mac mini installer
MWB_PIP_INDEX_URL=
MWB_PIP_EXTRA_INDEX_URL=
MWB_PIP_TRUSTED_HOST=
