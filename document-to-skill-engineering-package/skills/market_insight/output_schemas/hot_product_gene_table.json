{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "hot-product-gene-analysis-v1",
  "title": "Hot Product Gene Analysis",
  "description": "Evidence-aware product gene findings derived from a confirmed ranked-product sample.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product_profiles",
    "dimension_findings",
    "gene_groups",
    "coverage",
    "risks",
    "human_confirmation",
    "source_trace"
  ],
  "properties": {
    "schema_version": {
      "enum": ["hot-product-gene-analysis-v1", "hot-product-gene-analysis-confirmed-v1"]
    },
    "node_id": { "type": "string" },
    "execution_id": { "type": "string" },
    "source_table_ref": { "type": "string" },
    "source_revision": { "type": "integer", "minimum": 0 },
    "source_trace": { "$ref": "#/$defs/source_trace" },
    "sample_size": { "type": "integer", "minimum": 0 },
    "status": {
      "type": "string",
      "enum": ["running", "draft_ready", "cancelled", "stale", "confirmed"]
    },
    "classification_status": {
      "type": "string",
      "enum": ["evaluated", "insufficient_sample"]
    },
    "requested_model": { "type": "string" },
    "actual_models": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "product_profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/product_profile" }
    },
    "dimension_findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/dimension_finding" }
    },
    "gene_groups": {
      "type": "array",
      "items": { "$ref": "#/$defs/gene_group" }
    },
    "coverage": { "$ref": "#/$defs/coverage" },
    "progress": { "$ref": "#/$defs/progress" },
    "risks": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "human_confirmation": { "$ref": "#/$defs/human_confirmation" },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "finished_at": { "type": "string" },
    "artifact_path": { "type": "string" }
  },
  "$defs": {
    "source_trace": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "workflow_ref",
        "output_schema_refs",
        "business_doc_refs",
        "strategy_kb_refs",
        "api_doc_index_ref"
      ],
      "properties": {
        "workflow_ref": { "type": "string", "minLength": 1 },
        "output_schema_refs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "business_doc_refs": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 1,
          "uniqueItems": true
        },
        "strategy_kb_refs": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "api_doc_index_ref": { "type": "string", "minLength": 1 }
      }
    },
    "dimension": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "raw_value",
        "normalized_tags",
        "source_status",
        "confidence",
        "evidence_fields"
      ],
      "properties": {
        "raw_value": {},
        "normalized_tags": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "source_status": {
          "type": "string",
          "enum": [
            "api_fact",
            "missing",
            "deterministic_relative_band",
            "pi_derived_unconfirmed",
            "available",
            "unavailable",
            "insufficient_sample",
            "invalid"
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "evidence_fields": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "product_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["row_id", "rank", "dimensions", "gene_group_ids", "agent_status"],
      "properties": {
        "row_id": { "type": "string", "minLength": 1 },
        "goods_id": { "type": "string" },
        "rank": { "type": ["integer", "number", "string"] },
        "product_name": { "type": "string" },
        "product_url": { "type": "string" },
        "dimensions": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": { "$ref": "#/$defs/dimension" }
        },
        "gene_formula": { "type": "string" },
        "gene_group_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "agent_status": {
          "type": "string",
          "enum": ["queued", "running", "completed", "failed", "cancelled"]
        },
        "requested_model": { "type": "string" },
        "actual_model": { "type": "string" },
        "failure_reason": { "type": "string" },
        "source_row": { "type": "object" }
      }
    },
    "dimension_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["dimension", "covered_products", "total_products", "coverage_ratio", "top_tags"],
      "properties": {
        "dimension": { "type": "string", "minLength": 1 },
        "covered_products": { "type": "integer", "minimum": 0 },
        "total_products": { "type": "integer", "minimum": 0 },
        "coverage_ratio": { "type": "number", "minimum": 0, "maximum": 1 },
        "top_tags": {
          "type": "array",
          "items": { "$ref": "#/$defs/tag_finding" }
        }
      }
    },
    "tag_finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tag", "count", "ratio"],
      "properties": {
        "tag": { "type": "string", "minLength": 1 },
        "count": { "type": "integer", "minimum": 0 },
        "ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "gene_group": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "group_id",
        "normalized_gene_key",
        "member_row_ids",
        "product_count",
        "maturity",
        "gene_formula",
        "metrics",
        "classifications",
        "business_actions"
      ],
      "properties": {
        "group_id": { "type": "string", "minLength": 1 },
        "normalized_gene_key": { "type": "string", "minLength": 1 },
        "member_row_ids": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "product_count": { "type": "integer", "minimum": 1 },
        "maturity": { "type": "string", "enum": ["formal", "observation_candidate"] },
        "gene_formula": { "type": "string" },
        "metrics": { "$ref": "#/$defs/gene_metrics" },
        "classifications": {
          "type": "array",
          "items": { "$ref": "#/$defs/classification" }
        },
        "business_actions": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "gene_metrics": {
      "type": "object",
      "additionalProperties": false,
      "required": ["sample_ratio", "buyer_ratio", "gmv_ratio", "high_growth_ratio"],
      "properties": {
        "sample_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "buyer_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "gmv_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
        "high_growth_ratio": { "type": ["number", "null"], "minimum": 0, "maximum": 1 }
      }
    },
    "classification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "label", "status", "matched", "matched_count", "required_count", "signals"],
      "properties": {
        "rule_id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["matched", "not_matched", "insufficient_sample", "insufficient_evidence"]
        },
        "matched": { "type": "boolean" },
        "matched_count": { "type": "integer", "minimum": 0 },
        "required_count": { "const": 2 },
        "signals": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/signal" }
        }
      }
    },
    "signal": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "status": {
          "type": "string",
          "enum": ["matched", "not_matched", "unavailable", "insufficient_sample"]
        },
        "source_status": {
          "type": "string",
          "enum": ["available", "unavailable", "insufficient_sample"]
        },
        "available": { "type": "boolean" },
        "matched": { "type": ["boolean", "null"] },
        "value": {},
        "threshold": {},
        "comparator": { "type": "string", "enum": ["gte", "lt"] },
        "evidence_fields": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/coverage_item" }
    },
    "coverage_item": {
      "type": "object",
      "additionalProperties": false,
      "required": ["covered_products", "total_products", "ratio"],
      "properties": {
        "covered_products": { "type": "integer", "minimum": 0 },
        "total_products": { "type": "integer", "minimum": 0 },
        "ratio": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "progress": {
      "type": "object",
      "additionalProperties": false,
      "required": ["total_products", "completed_products", "running_products", "failed_products"],
      "properties": {
        "total_products": { "type": "integer", "minimum": 0 },
        "completed_products": { "type": "integer", "minimum": 0 },
        "running_products": { "type": "integer", "minimum": 0 },
        "failed_products": { "type": "integer", "minimum": 0 }
      }
    },
    "human_confirmation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status"],
      "properties": {
        "status": { "type": "string", "enum": ["unconfirmed", "confirmed", "rejected", "stale"] },
        "confirmed_by": { "type": "string" },
        "confirmed_at": { "type": "string" },
        "notes": { "type": "string" }
      }
    }
  }
}
